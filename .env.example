# ────────────── Model API ──────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# ────────────── Redis ──────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ────────────── Vector DB (Qdrant) ──────────────
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_COLLECTION=agent_memory

# ────────────── Sandbox ──────────────
SANDBOX_MODE=mock
SANDBOX_TIMEOUT=30

# ────────────── App ──────────────
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=DEBUG
MAX_MEMORY_TOKENS=4096
SUMMARY_TRIGGER_TOKENS=2048
TOP_K_MEMORY=5
TOP_K_SKILLS=3

# ── 第三方 MCP 服务（可选） ──
# LUCKIN_MCP_KEY=your_luckin_api_key_here

# ── A 股行情 MCP 服务（可选） ──
# TUSHARE_TOKEN=your_tushare_token_here    # 可选，用于数据源降级
# ENABLE_EASTMONEY_PATCH=true              # 东方财富接口限流时启用
